rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ATENCAO: sem autenticacao no app, estas regras ficam abertas para
    // leitura e escrita. Aceitavel para uso pessoal/interno; se outras
    // pessoas forem acessar o link, adicione Firebase Auth e troque para
    // "if request.auth != null" antes de divulgar o link.
    match /clientHistorico/{docId} {
      allow read, write: if true;
    }
    match /clientNotes/{clientId} {
      allow read, write: if true;
    }
  }
}
